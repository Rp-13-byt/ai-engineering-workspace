# Shared
ENVIRONMENT=local
LOG_LEVEL=INFO
PUBLIC_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Backend
DATABASE_URL=postgresql+asyncpg://workspace:workspace@postgres:5432/workspace
SYNC_DATABASE_URL=postgresql://workspace:workspace@postgres:5432/workspace
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://workspace:workspace@rabbitmq:5672/
JWT_SECRET=change-me-in-production
JWT_ISSUER=ai-workspace
JWT_AUDIENCE=ai-workspace-web
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
OPENAI_API_KEY=
GEMINI_API_KEY=
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=workspace
S3_SECRET_ACCESS_KEY=workspace-secret
S3_BUCKET=ai-workspace-artifacts

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
